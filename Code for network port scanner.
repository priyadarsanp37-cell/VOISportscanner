from scapy.all import IP, TCP, sr1, conf
import logging

# Suppress Scapy output for a cleaner console
logging.getLogger("scapy.runtime").setLevel(logging.ERROR)

def syn_scan(target_ip, ports):
    print(f"Starting TCP SYN scan on {target_ip}...")
    print(f"Scanning {len(ports)} ports...\n")
    
    open_ports = []

    for port in ports:
        # Create an IP packet to the target
        ip_pkt = IP(dst=target_ip)
        # Create a TCP SYN packet (Flags="S")
        tcp_pkt = TCP(dport=port, flags="S")
        
        # Send packet and wait for 1 response (timeout of 1 second)
        response = sr1(ip_pkt/tcp_pkt, timeout=1, verbose=0)

        if response is None:
            # No response usually means the port is filtered/dropped
            pass
        elif response.haslayer(TCP):
            if response.getlayer(TCP).flags == 0x12: # 0x12 is SYN-ACK
                # Send a Reset (RST) packet to close the connection gracefully
                rst_pkt = IP(dst=target_ip)/TCP(dport=port, flags="R")
                sr1(rst_pkt, timeout=1, verbose=0)
                open_ports.append(port)
                print(f"Port {port}: OPEN")
            elif response.getlayer(TCP).flags == 0x14: # 0x14 is RST-ACK
                # Port is closed
                pass

    return open_ports

if __name__ == "__main__":
    # Parameters from your scan report
    TARGET = "1.39.176.66"
    # A simplified "Top 10" list for brevity; you can expand this to 100
    TOP_100_PORTS = [21, 22, 23, 25, 53, 80, 110, 111, 135, 139, 143, 443, 445, 993, 995, 1723, 3306, 3389, 5900, 8080]

    results = syn_scan(TARGET, TOP_100_PORTS)

    print("\n--- Scan Results ---")
    if results:
        print(f"Found {len(results)} open ports: {results}")
    else:
        print("Found 0 open ports (1 host)")
