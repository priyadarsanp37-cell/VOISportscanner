import tkinter as tk
from tkinter import messagebox, scrolledtext
from scapy.all import IP, TCP, sr1
import threading
import logging

# Suppress Scapy output
logging.getLogger("scapy.runtime").setLevel(logging.ERROR)

class PortScannerGUI:
    def __init__(self, root):
        self.root = root
        self.root.title("Network Port Scanner (Stealth SYN Scan)")
        self.root.geometry("500x600")

        # --- UI Layout ---
        tk.Label(root, text="Network Port Scanner", font=("Arial", 16, "bold")).pack(pady=10)

        # Target IP Input
        tk.Label(root, text="Target IP Address:").pack()
        self.ip_entry = tk.Entry(root, width=30)
        self.ip_entry.insert(0, "1.39.176.66") # Default example
        self.ip_entry.pack(pady=5)

        # Common Ports Button
        self.scan_button = tk.Button(root, text="Start SYN Scan", command=self.start_scan_thread, 
                                     bg="#2ecc71", fg="white", font=("Arial", 10, "bold"), padx=20)
        self.scan_button.pack(pady=10)

        # Output Area
        tk.Label(root, text="Scan Results:").pack()
        self.output_area = scrolledtext.ScrolledText(root, width=55, height=20, state='disabled')
        self.output_area.pack(pady=5, padx=10)

        self.status_label = tk.Label(root, text="Status: Ready", fg="blue")
        self.status_label.pack(pady=5)

    def log(self, message):
        """Appends text to the GUI output area."""
        self.output_area.config(state='normal')
        self.output_area.insert(tk.END, message + "\n")
        self.output_area.config(state='disabled')
        self.output_area.see(tk.END)

    def start_scan_thread(self):
        """Runs the scan in a separate thread to prevent GUI freezing."""
        target_ip = self.ip_entry.get().strip()
        if not target_ip:
            messagebox.showerror("Error", "Please enter a valid IP address.")
            return

        self.scan_button.config(state='disabled')
        self.output_area.config(state='normal')
        self.output_area.delete(1.0, tk.END)
        self.output_area.config(state='disabled')
        
        # Define ports to scan (Top 20 most common)
        ports = [21, 22, 23, 25, 53, 80, 110, 111, 135, 139, 143, 443, 445, 993, 995, 1723, 3306, 3389, 5900, 8080]
        
        thread = threading.Thread(target=self.run_scanner, args=(target_ip, ports))
        thread.start()

    def run_scanner(self, target_ip, ports):
        """The actual scanning logic using Scapy."""
        self.status_label.config(text=f"Scanning {target_ip}...", fg="orange")
        self.log(f"Starting Stealth SYN Scan on {target_ip}...\n")
        
        open_ports = []

        for port in ports:
            try:
                # Create IP and SYN packets
                ip_pkt = IP(dst=target_ip)
                tcp_pkt = TCP(dport=port, flags="S")
                
                # Send and receive (1 second timeout)
                response = sr1(ip_pkt/tcp_pkt, timeout=1, verbose=0)

                if response is not None and response.haslayer(TCP):
                    if response.getlayer(TCP).flags == 0x12: # SYN-ACK
                        # Send RST to close the connection gracefully
                        rst_pkt = IP(dst=target_ip)/TCP(dport=port, flags="R")
                        sr1(rst_pkt, timeout=1, verbose=0)
                        
                        open_ports.append(port)
                        self.log(f"[+] Port {port}: OPEN")
                    elif response.getlayer(TCP).flags == 0x14: # RST-ACK
                        # Port is closed (optional: log if needed)
                        pass
            except Exception as e:
                self.log(f"[!] Error scanning port {port}: {str(e)}")

        self.log("\n--- Scan Complete ---")
        if open_ports:
            self.log(f"Final List of Open Ports: {open_ports}")
        else:
            self.log("No open ports detected.")

        self.status_label.config(text="Status: Finished", fg="green")
        self.scan_button.config(state='normal')

if __name__ == "__main__":
    root = tk.Tk()
    app = PortScannerGUI(root)
    root.mainloop()
